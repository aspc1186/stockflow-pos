{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "lib": ["ES2020"],
    "strict": false,
    "skipLibCheck": true,
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "outDir": ".vercel/output",
    "moduleDetection": "force"
  },
  "include": ["api/**/*.ts", "_auth.ts", "_db.ts"],
  "exclude": ["node_modules", "src", "dist"]
}